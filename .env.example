# Slope Indicator Service - env example
# 复制为 .env 并填真实值：cp .env.example .env

# ── Postgres（复用 PredictLab）─────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=predictlab
POSTGRES_USER=crawler
POSTGRES_PASSWORD=crawler123456

# ── HTTP 服务 ────────────────────────────────────────────────
SLOPE_PORT=8020
SLOPE_LOG_LEVEL=INFO

# ── 认证 ─────────────────────────────────────────────────────
# POST /recompute 必须带 X-Slope-Token header
# 如希望 GET /allow 和 /status 也要 token，设 SLOPE_REQUIRE_TOKEN=1
SLOPE_TOKEN=change-me-in-production
SLOPE_REQUIRE_TOKEN=0
